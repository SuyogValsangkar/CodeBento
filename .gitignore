# Ignores the following files and directories:

# Node.js dependencies
node_modules/
package-lock.json

# Rust build artifacts
/runner/target/
**/*.rs.bk
*.lock

# Vite / React build output
/frontend/dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
.env.*.local

# Spin-runner build artifacts
spin-runner/venv/
spin-runner/__pycache__/
spin-runner/*.pyc
spin-runner/*.pyo
spin-runner/app.wasm
spin-runner/.spin

# Spin signing artifacts
spin.sig
crt.pem

# Temporary files
*.tmp
*.swp
*.swo